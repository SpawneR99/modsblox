# ===== ModsBlox .env =====
# Copy this file to .env and fill in real values.
# Never commit the real .env to git.

# ---------- Server ----------
NODE_ENV=production
PORT=3000

# Directory for SQLite DB + uploads (mount this as a persistent volume in Coolify).
# Default: ./data relative to project root.
DATA_DIR=./data

# ---------- Session / Security ----------
# Random string, at least 64 chars. Generate with:  openssl rand -base64 64
SESSION_SECRET=change-me-to-a-long-random-string-at-least-64-characters

# ---------- Admin bootstrap ----------
# On first boot (no admin in DB), an admin row is created from these.
# Either provide ADMIN_PASSWORD_HASH (preferred, bcrypt) OR ADMIN_PASSWORD (plaintext, hashed at boot).
# After first boot you can clear these env vars (password lives hashed in DB) and change the
# password from the admin UI.
#
# Generate a bcrypt hash locally:   npm run hash -- 'YourStrongPassword!'
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=

# ---------- AdBlueMedia (provider) ----------
# Single-button CTA. The visitor's niche is appended as `?s1=<niche>`.
ADBLUEMEDIA_CLICK_URL=https://devicegetty.com/128efee

# ---------- OGAds (provider) ----------
# Single-button CTA. The visitor's niche is appended as `?aff_sub4=<niche>`.
OGADS_CLICK_URL=https://devicechecky.com/cl/i/qn61kw
