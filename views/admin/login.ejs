<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex,nofollow">
<title><%= title %> &mdash; ModsBlox Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Exo+2:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/static/admin.css">
</head>
<body class="login-shell">
  <form class="login-card" method="POST" action="/admin/login" autocomplete="off">
    <h1>ModsBlox</h1>
    <p class="sub">Administrator sign-in</p>
    <% if (error) { %><div class="login-error"><%= error %></div><% } %>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="next" value="<%= next %>">
    <div class="field">
      <label>Username</label>
      <input type="text" name="username" autocomplete="username" autofocus required>
    </div>
    <div class="field">
      <label>Password</label>
      <input type="password" name="password" autocomplete="current-password" required>
    </div>
    <button type="submit" class="btn btn-primary">Sign in</button>
  </form>
</body>
</html>
