<!DOCTYPE html>
<html lang="en">
<head>
<% const pageTitle = siteName + ' - Unlock ' + script.title; %>
<%- include('partials/head', { pageTitle }) %>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0d0221;--pink:#ff2d95;--cyan:#00fff0;--yellow:#ffe600;--card-bg:#160b30;--text:#e0d6ff;--text-dim:#8a7fad}
body{font-family:'Exo 2',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
body::after{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.03) 2px,rgba(0,0,0,.03) 4px);pointer-events:none;z-index:9999}
.grid-bg{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none}
.grid-bg canvas{width:100%;height:100%}
.container{position:relative;z-index:1;max-width:600px;margin:0 auto;padding:30px 20px}
.top-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px}
.back-btn{display:inline-flex;align-items:center;gap:8px;color:var(--cyan);text-decoration:none;font-weight:600;padding:10px 20px;border:1px solid rgba(0,255,240,.3);border-radius:8px;transition:all .2s;font-size:14px}
.back-btn:hover{background:rgba(0,255,240,.1)}
.brand{font-family:'Press Start 2P',cursive;font-size:12px;color:var(--pink);text-shadow:0 0 10px var(--pink)}
.badge{display:inline-block;background:linear-gradient(135deg,var(--pink),#ff6ec7);padding:6px 16px;border-radius:20px;font-family:'Press Start 2P',cursive;font-size:8px;color:#fff;text-align:center;margin:0 auto 12px;display:block;width:fit-content}
.title{font-family:'Press Start 2P',cursive;font-size:16px;color:var(--cyan);text-shadow:0 0 10px var(--cyan);text-align:center;margin-bottom:24px;line-height:1.6}
.stats-row{display:flex;gap:12px;margin-bottom:24px}
.stat-box{flex:1;background:var(--card-bg);border:1px solid rgba(255,45,149,.12);border-radius:10px;padding:14px;text-align:center}
.stat-box .num{font-family:'Press Start 2P',cursive;font-size:14px;color:var(--cyan);display:block;margin-bottom:4px}
.stat-box .lbl{font-size:11px;color:var(--text-dim)}
.locked-card{background:var(--card-bg);border:1px solid rgba(255,45,149,.15);border-radius:16px;padding:24px;margin-bottom:24px}
.key-display{background:rgba(0,0,0,.3);border:1px solid rgba(0,255,240,.15);border-radius:8px;padding:14px;text-align:center;margin-bottom:16px;position:relative;overflow:hidden}
.key-display .key-text{font-family:'Press Start 2P',cursive;font-size:12px;color:var(--cyan);filter:blur(5px);transition:filter .3s}
.key-display.unlocked .key-text{filter:none}
.key-display .lock-icon{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:24px}
.key-display.unlocked .lock-icon{display:none}
.unlock-status{display:flex;align-items:center;justify-content:center;gap:8px;font-size:13px;margin-bottom:16px}
.unlock-status .icon{font-size:18px}
.unlock-status.locked{color:var(--pink)}
.unlock-status.unlocked{color:#0f0}
.progress-section{margin-bottom:20px}
.progress-section .label{display:flex;justify-content:space-between;font-size:12px;color:var(--text-dim);margin-bottom:8px}
.progress-track{width:100%;height:8px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden}
.progress-track .fill{height:100%;width:0%;background:linear-gradient(90deg,var(--pink),var(--cyan));border-radius:4px;transition:width .5s}
.video-section{background:var(--card-bg);border:1px solid rgba(255,45,149,.12);border-radius:12px;padding:20px;margin-bottom:24px;text-align:center}
.video-section h3{font-family:'Press Start 2P',cursive;font-size:10px;color:var(--yellow);margin-bottom:12px}
.video-section a{color:var(--cyan);text-decoration:none;font-weight:600;padding:10px 20px;border:1px solid rgba(0,255,240,.3);border-radius:8px;display:inline-block;transition:all .2s}
.video-section a:hover{background:rgba(0,255,240,.1)}
.tasks-section h3{font-family:'Press Start 2P',cursive;font-size:11px;color:var(--pink);margin-bottom:16px}
.offers-grid{display:flex;flex-direction:column;gap:12px;margin-bottom:24px;min-height:100px}
.offer-card{display:flex;align-items:flex-start;gap:14px;background:var(--card-bg);border:1px solid rgba(255,45,149,.12);border-radius:10px;padding:16px;cursor:pointer;transition:all .2s;text-decoration:none;color:var(--text)}
.offer-card:hover{border-color:var(--pink);box-shadow:0 0 15px rgba(255,45,149,.2);transform:translateY(-1px)}
.offer-card .offer-icon{width:56px;height:56px;border-radius:10px;background:rgba(255,45,149,.1);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;overflow:hidden}
.offer-card .offer-icon img{width:100%;height:100%;object-fit:cover;border-radius:10px}
.offer-card .offer-info{flex:1;min-width:0}
.offer-card .offer-info h4{font-size:14px;font-weight:700;margin-bottom:6px;line-height:1.3;color:var(--text)}
.offer-card .offer-info p{font-size:12px;color:var(--text-dim);line-height:1.6;white-space:pre-line;word-break:break-word}
.offer-card .offer-arrow{color:var(--text-dim);font-size:18px;align-self:center;flex-shrink:0}
.loading-offers{text-align:center;padding:30px;color:var(--text-dim);font-size:13px}
.cta-wrap{display:flex;flex-direction:column;align-items:center;gap:10px;padding:6px 0 4px}
.cta-btn{position:relative;display:inline-block;width:100%;max-width:420px;text-align:center;padding:22px 28px;border-radius:14px;font-family:'Press Start 2P',cursive;font-size:15px;letter-spacing:.5px;color:#0d0221;text-decoration:none;background:linear-gradient(135deg,var(--pink),var(--cyan));box-shadow:0 0 28px rgba(0,255,240,.35),0 0 12px rgba(255,45,149,.35) inset;overflow:hidden;animation:ctaPulse 1.4s ease-in-out infinite;will-change:transform,box-shadow;cursor:pointer}
.cta-btn span.arrow{margin-left:8px;display:inline-block;animation:ctaArrow 1s ease-in-out infinite}
.cta-btn:hover{transform:scale(1.03);animation-play-state:paused}
.cta-btn::after{content:'';position:absolute;top:0;left:-60%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.45),transparent);transform:skewX(-20deg);animation:ctaShine 2.2s linear infinite;pointer-events:none}
.cta-sub{font-size:12px;color:var(--text-dim);font-style:italic;text-align:center;letter-spacing:.3px}
.cta-sub strong{color:var(--yellow);font-style:normal;font-family:'Press Start 2P',cursive;font-size:9px;margin-right:6px}
@keyframes ctaPulse{0%,100%{transform:scale(1);box-shadow:0 0 28px rgba(0,255,240,.35),0 0 12px rgba(255,45,149,.35) inset}50%{transform:scale(1.03);box-shadow:0 0 46px rgba(255,45,149,.75),0 0 18px rgba(0,255,240,.55) inset}}
@keyframes ctaShine{0%{left:-60%}100%{left:120%}}
@keyframes ctaArrow{0%,100%{transform:translateX(0)}50%{transform:translateX(5px)}}
.how-to{background:var(--card-bg);border:1px solid rgba(255,45,149,.12);border-radius:12px;padding:20px;margin-bottom:24px}
.how-to h3{font-family:'Press Start 2P',cursive;font-size:10px;color:var(--cyan);margin-bottom:16px}
.how-to ol{padding-left:20px}
.how-to li{color:var(--text-dim);font-size:13px;padding:6px 0;line-height:1.6}
.hints{background:rgba(255,230,0,.04);border:1px solid rgba(255,230,0,.15);border-radius:10px;padding:16px;margin-bottom:24px}
.hints h4{font-family:'Press Start 2P',cursive;font-size:9px;color:var(--yellow);margin-bottom:10px}
.hints p{font-size:12px;color:var(--text-dim);line-height:1.6;margin-bottom:6px}
.toast{position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(100px);background:linear-gradient(135deg,#0f0,var(--cyan));color:var(--bg);font-family:'Press Start 2P',cursive;font-size:10px;padding:16px 28px;border-radius:12px;z-index:10000;transition:transform .4s;box-shadow:0 0 30px rgba(0,255,240,.5)}
.toast.show{transform:translateX(-50%) translateY(0)}
@media(max-width:600px){.stats-row{flex-direction:column}.title{font-size:12px}.offer-card .offer-icon{width:44px;height:44px}}
</style>
</head>
<body>
<%- include('partials/grid-bg') %>
<div class="toast" id="toast">\u{1F389} SCRIPT UNLOCKED!</div>
<div class="container">
  <div class="top-bar">
    <a href="/s/<%= script.slug %>" class="back-btn">&larr; Back</a>
    <div class="brand"><%= siteName %></div>
  </div>
  <div class="badge">SCRIPT READY</div>
  <div class="title">Script is Ready!</div>

  <div class="stats-row">
    <div class="stat-box"><span class="num" id="statUsers">0</span><span class="lbl">Users Online</span></div>
    <div class="stat-box"><span class="num" id="statKeys">0</span><span class="lbl">Keys Left</span></div>
    <div class="stat-box"><span class="num" id="statExpires">15:00</span><span class="lbl">Expires In</span></div>
  </div>

  <div class="locked-card">
    <div class="key-display" id="keyDisplay">
      <span class="key-text" id="keyText"><%= script.key_prefix %>-XXXX-XXXX-XXXX</span>
      <span class="lock-icon">&#128274;</span>
    </div>
    <div class="unlock-status locked" id="unlockStatus"><span class="icon">&#128274;</span> Locked &mdash; Complete tasks below</div>
    <div class="progress-section">
      <div class="label"><span>Progress</span><span id="progressLabel">0 / <%= offerMin %> completed</span></div>
      <div class="progress-track"><div class="fill" id="progressFill"></div></div>
    </div>
  </div>

  <% if (videoGuide) { %>
  <div class="video-section">
    <h3>&#128249; VIDEO GUIDE</h3>
    <a href="<%= videoGuide %>" target="_blank" rel="noopener">Watch How to Complete &rarr;</a>
  </div>
  <% } %>

  <div class="tasks-section">
    <h3 id="tasksHeading">&#9889; COMPLETE <%= offerMin %> TASKS TO UNLOCK</h3>
    <div class="offers-grid" id="offersGrid">
      <div class="loading-offers">Loading available tasks...</div>
    </div>
  </div>

  <div class="how-to">
    <h3>HOW TO COMPLETE</h3>
    <ol id="howToList">
      <li>Click on any task from the list above</li>
      <li>Follow the instructions on the offer page</li>
      <li>Complete the task fully (install app, finish survey, etc.)</li>
      <li>Return here &mdash; your progress updates automatically</li>
      <li>Complete <%= offerMin %> tasks to unlock your script</li>
    </ol>
  </div>

  <div class="hints">
    <h4>&#128161; TIPS FOR FAST COMPLETION</h4>
    <p>&bull; <strong>Use your real email</strong> &mdash; fake emails won't get credited and you'll waste time.</p>
    <p>&bull; <strong>App installs are fastest</strong> &mdash; just download, open for 30 seconds, done!</p>
    <p>&bull; If a task doesn't credit, try a different one.</p>
    <p>&bull; Disable ad blockers for best results.</p>
  </div>
</div>

<script>
const SCRIPT_SLUG='<%= script.slug %>';
const NICHE='<%= script.niche %>';
const KEY_PREFIX='<%= script.key_prefix %>';
let MIN_COMPLETE=<%= offerMin %>;
const VPATH='<%= script.vpath %>/locker';
if(typeof umami!=='undefined')umami.track(p=>({...p,url:VPATH}));

let fakeUsers=Math.floor(Math.random()*300)+150;
let fakeKeys=Math.floor(Math.random()*40)+10;
document.getElementById('statUsers').textContent=fakeUsers;
document.getElementById('statKeys').textContent=fakeKeys;
setInterval(()=>{
  fakeUsers+=Math.floor(Math.random()*5)-2;if(fakeUsers<100)fakeUsers=100;
  fakeKeys-=Math.random()>.7?1:0;if(fakeKeys<5)fakeKeys=Math.floor(Math.random()*10)+5;
  document.getElementById('statUsers').textContent=fakeUsers;
  document.getElementById('statKeys').textContent=fakeKeys;
},4000);

let expireSeconds=900;
setInterval(()=>{
  expireSeconds--;if(expireSeconds<0)expireSeconds=900;
  const m=Math.floor(expireSeconds/60),s=expireSeconds%60;
  document.getElementById('statExpires').textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
},1000);

document.getElementById('keyText').textContent=KEY_PREFIX+'-'+rand(4)+'-'+rand(4)+'-'+rand(4);
function rand(n){let s='';for(let i=0;i<n;i++)s+='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'[Math.floor(Math.random()*36)];return s}

function escapeHtml(s){return String(s||'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}

function renderButtonMode(ctaUrl){
  MIN_COMPLETE=1;
  const grid=document.getElementById('offersGrid');
  const heading=document.getElementById('tasksHeading');
  const howTo=document.getElementById('howToList');
  if(heading)heading.innerHTML='&#9889; LAST STEP TO UNLOCK';
  grid.innerHTML=
    '<div class="cta-wrap">'+
      '<a class="cta-btn" id="ctaBtn" href="'+escapeHtml(ctaUrl)+'" target="_blank" rel="noopener noreferrer">Click Here<span class="arrow">&rarr;</span></a>'+
      '<div class="cta-sub"><strong>LAST STEP</strong>Tap the button to reveal your tasks</div>'+
    '</div>';
  const btn=document.getElementById('ctaBtn');
  if(btn)btn.addEventListener('click',()=>trackOffer('__ogads_cta__'));
  if(howTo){
    howTo.innerHTML=
      '<li>Click the glowing <strong>Click Here</strong> button above</li>'+
      '<li>A new page opens with a short list of tasks</li>'+
      '<li>Pick one task and follow the steps shown there</li>'+
      '<li>Complete the task fully (install app, finish survey, etc.)</li>'+
      '<li>Return here &mdash; your script unlocks automatically</li>';
  }
}

async function loadOffers(){
  const grid=document.getElementById('offersGrid');
  try{
    const res=await fetch('/api/offers?slug='+encodeURIComponent(SCRIPT_SLUG));
    if(!res.ok)throw new Error('HTTP '+res.status);
    const d=await res.json();
    if(d&&d.success&&d.mode==='button'&&d.ctaUrl){
      renderButtonMode(d.ctaUrl);
      checkUnlock();
      return;
    }
    if(!d.success||!d.offers||!d.offers.length)throw new Error(d.error||'No offers');
    grid.innerHTML='';
    d.offers.forEach(o=>{
      const card=document.createElement('a');
      card.className='offer-card';
      card.href=o.url||'#';card.target='_blank';card.rel='noopener noreferrer';
      card.addEventListener('click',()=>trackOffer(o.id));
      const icon=o.icon
        ? '<img src="'+escapeHtml(o.icon)+'" alt="" loading="lazy" onerror="this.remove()">'
        : '<span>&#128230;</span>';
      card.innerHTML =
        '<div class="offer-icon">'+icon+'</div>'+
        '<div class="offer-info">'+
          '<h4>'+escapeHtml(o.title)+'</h4>'+
          '<p>'+escapeHtml(o.description || 'Complete this task to earn credit.')+'</p>'+
        '</div>'+
        '<span class="offer-arrow">&rarr;</span>';
      grid.appendChild(card);
    });
  }catch(e){
    grid.innerHTML='<div class="loading-offers">Tasks are loading. Please refresh in a moment.</div>';
  }
}
loadOffers();

function trackOffer(id){
  const key='completedOffers_'+NICHE;
  let completed=JSON.parse(localStorage.getItem(key)||'[]');
  if(!completed.includes(id)){completed.push(id);localStorage.setItem(key,JSON.stringify(completed))}
  checkUnlock();
}

function checkUnlock(){
  const completed=JSON.parse(localStorage.getItem('completedOffers_'+NICHE)||'[]');
  const count=Math.min(completed.length,MIN_COMPLETE);
  document.getElementById('progressLabel').textContent=count+' / '+MIN_COMPLETE+' completed';
  document.getElementById('progressFill').style.width=(count/MIN_COMPLETE*100)+'%';
  if(count>=MIN_COMPLETE){
    document.getElementById('keyDisplay').classList.add('unlocked');
    document.getElementById('unlockStatus').className='unlock-status unlocked';
    document.getElementById('unlockStatus').innerHTML='<span class="icon">&#128275;</span> Unlocked!';
    const t=document.getElementById('toast');t.classList.add('show');setTimeout(()=>t.classList.remove('show'),4000);
  }
}
checkUnlock();
</script>
</body>
</html>
